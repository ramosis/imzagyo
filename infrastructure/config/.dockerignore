.vscode
.env
.pytest_cache
node_modules
venv
__pycache__
*.pyc
*.pyo
*.pyd
.db
data/*.db
logs/*.log
uploads/*
test_results.txt
scripts/
docs/
legal/
extension/
extension-pro/
mobile/
shared/schemas.py.bak
