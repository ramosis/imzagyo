# infrastructure/config/.env.example
# ============================================
# İMZA GAYRİMENKUL - ENVIRONMENT CONFIG
# ============================================

# APP
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=True

# DATABASE
DATABASE_URL=postgresql://imza:imza_password@localhost:5432/imza_dev
# Eski: DATABASE_URL=sqlite:///data/imza_database.db

# DOMAINS
INVESTMENT_DOMAIN=imzaemlak.com
NEIGHBORHOOD_DOMAIN=imzamahalle.com

# API KEYS
GEMINI_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SAHIBINDEN_API_KEY=
HEPSEMLAK_API_KEY=

# ADDONS (virgülle ayrılmış)
ENABLED_ADDONS=ai,compass,media,analytics

# SECURITY
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
RATE_LIMIT_DEFAULT=100 per minute

# MAIL
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SENTRY (opsiyonel)
SENTRY_DSN=
