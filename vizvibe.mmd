flowchart TD
    %% === PROJE HEDEFLERİ ===
    %% Ultimate Goal: İmza Gayrimenkul portalını modern UI/UX ve birleşik mantıkla yeniden inşa etmek.
    %% Current Goal: Klasör yapısını modernize etmek ve yeni özellikler için hazır hale getirmek.

    %% === KULLANICI KATMANI ===
    subgraph Users [Kullanıcı Katmanı]
        visitor("Ziyaretçi<br/><sub>İlanları gezer, arama yapar<br/>ve iletişim formu doldurur</sub>")
        investor("Yatırımcı<br/><sub>Portföy analizlerini görür,<br/>AI fırsat rotasını kullanır</sub>")
        admin("Danışman / Admin<br/><sub>Müşteri yönetimi, sözleşme<br/>oluşturma ve ilan girişi yapar</sub>")
    end

    %% === UYGULAMA KATMANI ===
    subgraph Apps [Uygulama Katmanı]
        frontend("Web Frontend<br/><sub>pages/ klasöründe toplanmış<br/>Premium HTML/JS arayüzü</sub>")
        mobile("Mobil Uygulama<br/><sub>Expo / React Native<br/>iOS & Android</sub>")
    end

    %% === API & BACKEND KATMANI ===
    subgraph Backend [API & Backend Katmanı]
        flask_api("Flask Python API<br/><sub>pages/ ve root servisleri<br/>merkezi iş mantığı</sub>")
        db[("Veritabanı<br/><sub>Mülkler, Müşteriler<br/>ve Sistem Ayarları</sub>")]
        gemini_ai("Gemini AI Servisi<br/><sub>Otomatik ilan hikayesi ve<br/>portföy analizi üretimi</sub>")
        mail_service("E-Posta Servisi<br/><sub>Google Workspace tabanlı<br/>bildirim ve şifre işlemleri</sub>")
    end

    %% === ALTYAPI & DAĞITIM ===
    subgraph Infra [Altyapı & Dağıtım]
        docker("Docker & Compose<br/><sub>Root dizininde korunan<br/>dağıtım konfigürasyonu</sub>")
        nginx("Nginx Proxy<br/><sub>SSL yönetimi, Domain<br/>yönlendirme (imzaemlak.com)</sub>")
        gcp_vps("Google Cloud VPS<br/><sub>Esnek ve ölçeklenebilir<br/>bulut sunucu altyapısı</sub>")
    end

    %% === İLİŞKİLER ===
    visitor & investor --> frontend
    visitor & investor --> mobile
    admin --> frontend

    frontend & mobile <==> flask_api
    flask_api <==> db
    flask_api --> gemini_ai
    flask_api --> mail_service

    flask_api & db & nginx --> docker
    docker --> gcp_vps
    nginx <--> Apps

    %% === GELİŞİM ÇİZGELGESİ (TRAJECTORY) ===
    subgraph Trajectory [Gelişim Yolculuğu]
        direction LR
        %% @project_start [start, closed, 2026-03-01, nam]
        start("Başlangıç")
        
        %% @feature_leads [ai-task, closed, 2026-03-05, nam]
        leads("CRM Altyapı")
        
        %% @feature_contract_builder [ai-task, closed, 2026-03-10, nam]
        contracts("Sözleşme Sihirbazı")
        
        %% @feature_ai_integration [ai-task, closed, 2026-03-10, nam]
        ai("AI Entegrasyonu")
        
        %% @feature_docker_deployment [ai-task, closed, 2026-03-11, nam]
        deploy("Canlı Dağıtım")
        
        %% @feature_mobile_ui_fixes [ai-task, closed, 2026-03-12, antigravity]
        mobile_fix("Mobil & UI Fix")
        
        %% @feature_performance_opt [ai-task, closed, 2026-03-12, antigravity]
        perf_opt("Performans Turbo")

        %% @feature_cloudinary [ai-task, closed, 2026-03-12, antigravity]
        cloudinary("Bulut Depolama")

        %% @feature_cleanup [ai-task, closed, 2026-03-14, antigravity]
        cleanup("Yama & Temizlik")

        %% @feature_refactor [ai-task, closed, 2026-03-14, antigravity]
        refactor("Klasör Refaktörü<br/><sub>Dokümanlar docs/, sayfalar pages/<br/>altına alındı; app.py yeni<br/>yapıya göre optimize edildi</sub>")

        %% @feature_design_standard [ai-task, closed, 2026-03-14, antigravity]
        design_standard("Tasarım Standardizasyonu<br/><sub>Tüm sayfalarda 1.1s Maybach hızı,<br/>12px Montserrat nav fontu ve<br/>premium marka uyumu sağlandı</sub>")

        %% @feature_mobile_web [ai-task, closed, 2026-03-15, antigravity]
        mobile_web("Mobil Web Geliştirme<br/><sub>1.1s Maybach senkronizasyonu,<br/>responsive görsel optimizasyonu (srcset)<br/>ve PWA (manifest/sw) entegrasyonu</sub>")

        %% @ultimate_goal [end, opened, 2026-03-15, nam]
        goal("Büyük Hedef")

        start --> leads --> contracts --> ai --> deploy --> mobile_fix --> perf_opt --> cloudinary --> cleanup --> refactor --> portal_fix --> server_up --> design_standard --> mobile_test --> mobile_web -.-> goal
    end

    %% === RECENT WORK HIGHLIGHT ===
    subgraph recent [SON ÇALIŞMA]
        mobile_web
    end

