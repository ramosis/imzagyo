    portal_auth_fix("Portal & Server Stabilizasyonu<br/><sub>Jinja2 render_template geçişi yapıldı,<br/>portföy fiyat serilizasyon hatası<br/>(Float->Str) giderildi ve portal<br/>girişi tamamen restore edildi.</sub>")

