flowchart TD
    %% === PROJECT GOALS ===
    %% Ultimate Goal: Reconstruct the imzagyo property management portal with unified logic and modern UI/UX.
    %% Current Goal: Finalize the consolidated portal script and verify all core feature integrations.

    %% === START ===
    %% @project_start [start, closed, 2026-03-01, nam]
    project_start("Project Start<br/><sub>Initial development of the Imza<br/>Property Management Portal,<br/>focusing on listing and<br/>lead management</sub>")

    %% @ultimate_goal [end, opened, 2026-03-15, nam]
    ultimate_goal("Project Goal<br/><sub>Fully integrated and automated<br/>property portal with AI content<br/>generation and contract<br/>management functionality</sub>")

    %% === COMPLETED WORK ===
    %% @feature_leads [ai-task, closed, 2026-03-05, nam]
    feature_leads("Lead Management<br/><sub>Implemented lead scoring,<br/>WhatsApp template integration,<br/>and automated lead fetching<br/>from the web form</sub>")

    %% @feature_appointments_v2 [ai-task, closed, 2026-03-10, nam]
    feature_appointments_v2("Appointments V2<br/><sub>Refined appointment management<br/>with date/time pickers, status<br/>tracking, and UI-optimized<br/>modal flows</sub>")

    %% @feature_contract_builder [ai-task, closed, 2026-03-10, nam]
    feature_contract_builder("Contract Builder<br/><sub>Implemented a multi-step<br/>contract wizard with party<br/>search, property selection,<br/>and draft generation</sub>")

    %% @feature_ai_integration [ai-task, closed, 2026-03-10, nam]
    feature_ai_integration("AI Story Generation<br/><sub>Integrated Gemini AI to<br/>automatically generate property<br/>descriptions based on metadata<br/>and features</sub>")

    %% @task_consolidation [ai-task, closed, 2026-03-10, nam]
    task_consolidation("Script Consolidation<br/><sub>Unified portal logic into a<br/>single organized script block,<br/>removing 3,300+ redundant lines<br/>and fixing syntax errors</sub>")

    %% === FUTURE WORK ===
    %% @future_integrations [ai-task, opened, 2026-03-11, nam]
    future_integrations("Platform Integrations<br/><sub>Implement automated property<br/>publishing to Sahibinden,<br/>Hepsiemlak, and Emlakjet<br/>via API hooks</sub>")

    %% @future_payroll_api [ai-task, opened, 2026-03-12, nam]
    future_payroll_api("Payroll (Hakediş) API<br/><sub>Develop the backend API to<br/>calculate commissions and<br/>expenses for the payroll<br/>management module</sub>")

    %% === CONNECTIONS ===
    project_start --> feature_leads
    feature_leads --> feature_appointments_v2
    feature_appointments_v2 --> feature_contract_builder
    feature_contract_builder --> feature_ai_integration
    feature_ai_integration --> task_consolidation
    task_consolidation --> future_integrations
    task_consolidation --> future_payroll_api
    future_integrations -.-> ultimate_goal
    future_payroll_api -.-> ultimate_goal

    %% === RECENT WORK HIGHLIGHT ===
    subgraph recent [RECENT]
        task_consolidation
    end

    %% === STYLES ===
