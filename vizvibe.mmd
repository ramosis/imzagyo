flowchart TD
    %% === PROJE HEDEFLERİ ===
    %% Ultimate Goal: İmza Gayrimenkul portalını modern UI/UX, akıllı analiz ve birleşik mantıkla yeniden inşa etmek.
    %% Current Goal: İmza Lens zekasıyla kullanıcı davranışlarını analiz etmek ve kişiselleştirilmiş deneyim sunmak.

    %% === KULLANICI KATMANI ===
    subgraph Users [Kullanıcı Katmanı]
        visitor("Ziyaretçi<br/><sub>İlanları gezer, arama yapar<br/>ve iletişim formu doldurur</sub>")
        investor("Yatırımcı<br/><sub>Portföy analizlerini görür,<br/>AI fırsat rotasını kullanır</sub>")
        admin("Danışman / Admin<br/><sub>Müşteri yönetimi, sözleşme<br/>oluşturma ve ilan girişi yapar</sub>")
    end

    %% === UYGULAMA KATMANI ===
    subgraph Apps [Uygulama Katmanı]
        frontend("Web Frontend<br/><sub>pages/ klasöründe toplanmış<br/>Premium HTML/JS arayüzü</sub>")
        imza_lens("İmza Lens Module<br/><sub>Akıllı karşılama, Geo-Targeting<br/>ve davranışsal analiz motoru</sub>")
    end

    %% === API & BACKEND KATMANI ===
    subgraph Backend [API & Backend Katmanı]
        flask_api("Flask Python API<br/><sub>pages/ ve root servisleri<br/>merkezi iş mantığı</sub>")
        db[("Veritabanı<br/><sub>Mülkler, Müşteriler<br/>ve Sistem Ayarları</sub>")]
        geo_api("FreeIPAPI Integration<br/><sub>IP tabanlı konum tespiti ve<br/>yerelleştirilmiş karşılama</sub>")
    end

    %% === ALTYAPI & DAĞITIM ===
    subgraph Infra [Altyapı & Dağıtım]
        docker("Docker & Compose<br/><sub>Root dizininde korunan<br/>dağıtım konfigürasyonu</sub>")
        pwa("PWA & Service Worker<br/><sub>Offline destek ve v2<br/>önbellek yönetimi (sw.js)</sub>")
        data_logs("Data & Logs<br/><sub>data/ klasöründe toplanmış<br/>veritabanı, log ve yedekler</sub>")
    end

    %% === İLİŞKİLER ===
    visitor & investor --> frontend
    frontend --> imza_lens
    imza_lens <--> geo_api
    imza_lens -- "Shadow Bridge" --> flask_api
    admin --> frontend

    frontend <==> flask_api
    flask_api <==> db
    flask_api & db --> docker
    frontend --> pwa

    %% === GELİŞİM ÇİZGELGESİ (TRAJECTORY) ===
    subgraph Trajectory [Gelişim Yolculuğu]
        direction LR
        %% @project_start [start, closed, 2026-03-01, nam]
        start("Başlangıç")
        
        %% @feature_refactor [ai-task, closed, 2026-03-14, antigravity]
        refactor("Yeniden Yapılanma")

        %% @feature_mobile_web [ai-task, closed, 2026-03-15, antigravity]
        mobile_web("Mobil & PWA")

        %% @feature_l_metrics [ai-task, closed, 2026-03-16, antigravity]
        l_metrics("L-Metrics (Faz 11)<br/><sub>Ziyaretçilerin scroll ve odaklanma<br/>kalitesini ölçen derinlik analiz<br/>motoru (Luxury Metrics) aktif edildi</sub>")

        %% @feature_geo_seo [ai-task, closed, 2026-03-17, antigravity]
        geo_seo("SEO & Geo Lens (Faz 12)<br/><sub>IP-Geo ile şehir bazlı karşılama<br/>ve kullanıcı ilgisine göre dinamik<br/>meta-tag optimizasyonu tamamlandı</sub>")

        %% @feature_shadow_bridge [ai-task, closed, 2026-03-17, antigravity]
        shadow_bridge("Shadow Bridge (Faz 13)<br/><sub>Anonim verilerin arka planda<br/>senkronize edilmesi ve yönetici<br/>görünürlüğü altyapısı kuruldu</sub>")

        %% @feature_campaign_module [ai-task, closed, 2026-03-17, antigravity]
        campaign("Kampanya Modülü (Faz 14)<br/><sub>Hero slider kampanya enjeksiyonu,<br/>merkezi talep formu ve L-Metrics<br/>backend entegrasyonu tamamlandı</sub>")

        %% @feature_mobile_ops [ai-task, closed, 2026-03-17, antigravity]
        mobile_ops("Mobil Operasyon (Faz 18)<br/><sub>Personel/Yönetici için CRM,<br/>AJANDA ve ekip takibi<br/>entegrasyonu tamamlandı</sub>")

        %% @ultimate_goal [end, opened, 2026-03-17, nam]
        goal("Büyük Hedef")

        %% @env_setup [ai-task, opened, 2026-03-18, antigravity]
        env_setup("Android Ortamı<br/><sub>Android Studio (3GB+) ve<br/>JDK 17 kurulumu devam ediyor.<br/>APK derlemesi için ön koşul</sub>")

        %% @feature_extension_mvp [ai-task, closed, 2026-03-18, antigravity]
        extension_mvp("Eklenti MVP (Faz 23)<br/><sub>Manifest V3, Popup UI ve<br/>temel scraping mantığı kuruldu.<br/>Geliştirme süreci tamamlandı</sub>")

        %% @feature_extension_sync [ai-task, closed, 2026-03-18, antigravity]
        extension_sync("Eklenti Senkronizasyonu<br/><sub>Shadow Mode verilerinin Flask<br/>backend ile anlık senkronizasyonu<br/>altyapısı (API+DB) kuruldu</sub>")

    %% @imza_lens_merkezi [ai-task, closed, 2026-03-18, antigravity]
    imza_lens_merkezi("İmza Lens Merkezi Panel (Faz 24)<br/><sub>Shadow ve L-Metrics sekmeleri<br/>birleştirildi. Port 8000 ve canlı<br/>sunucu (API) optimizasyonu yapıldı.</sub>")

    %% @feature_deep_scraping [ai-task, closed, 2026-03-18, antigravity]
    deep_scraping("Derin Veri Kazıma (Faz 25)<br/><sub>İl, İlçe, Mahalle ve Koordinat<br/>bazlı scraping mantığı kuruldu.<br/>Portalda harita entegrasyonu aktif.</sub>")

    %% @feature_roi_analysis [ai-task, closed, 2026-03-18, antigravity]
    roi_analysis("Bölgesel ROI (Faz 26)<br/><sub>Veritabanında biriken kiralık<br/>ilan verileriyle satış ilanlarına<br/>gerçekçi amortisman analizi yapıldı.</sub>")

        %% @extension_ui_overhaul [ai-task, closed, 2026-03-18, antigravity]
        extension_ui_overhaul("Eklenti UI & Scraping (Faz 27)<br/><sub>Popup UI yenileme, Manual Override<br/>ve detaylı m2 (Net/Brüt) tespiti<br/>ile scraping mantığı güçlendirildi</sub>")

        start --> refactor --> mobile_web --> l_metrics --> geo_seo --> shadow_bridge --> campaign --> admin_fix --> mobile_ops --> extensions
        extensions --> extension_mvp --> extension_sync --> imza_lens_merkezi --> deep_scraping --> roi_analysis
        roi_analysis --> extension_ui_overhaul --> env_setup
        env_setup -.-> goal
    end

